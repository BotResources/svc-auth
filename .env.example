# --- Required ---
NATS_URL=nats://nats:4222
JWT_SECRET=change-me-to-a-strong-random-secret

# --- Optional (defaults shown) ---
JWT_ISSUER=svc-auth
JWT_ACCESS_TOKEN_TTL=900          # 15 minutes
JWT_REFRESH_TOKEN_TTL=604800      # 7 days
PORT=8002
ENVIRONMENT=local                 # local | dev | test | prod
SECURE_COOKIES=false              # Use __Host- prefix + Secure flag on cookies
RUST_LOG=info                     # tracing filter (debug, info, warn, error)
JWKS_REFRESH_COOLDOWN_SECONDS=60  # Min delay between JWKS re-fetches per provider (kid-miss storm protection, floor 1)

# --- Auth subrequest behavior ---
# When true (default), /auth/check performs silent refresh on expired JWT
# and returns 200 + Set-Cookie. Required for nginx/OpenResty (which can
# forward Set-Cookie from auth subrequests via Lua).
#
# Set to false when running behind k8s ingress middlewares that cannot
# forward Set-Cookie from auth responses: Traefik ForwardAuth, nginx-ingress
# `auth-url`, Envoy ExternalAuthz. In that mode /auth/check returns 401 on
# expired/invalid JWT and the client is expected to call /auth/refresh
# explicitly (standard SPA pattern).
AUTH_CHECK_SILENT_REFRESH=true

# --- OIDC providers (auto-detected by prefix) ---
# Each provider needs OIDC_{NAME}_DISCOVERY_URL and OIDC_{NAME}_CLIENT_ID.
# OIDC_{NAME}_EMAIL_CLAIM is optional (default: "email").
#
# Example: Entra (Microsoft)
# OIDC_ENTRA_DISCOVERY_URL=https://login.microsoftonline.com/{tenant}/v2.0
# OIDC_ENTRA_CLIENT_ID=your-client-id
# OIDC_ENTRA_EMAIL_CLAIM=preferred_username
#
# Example: Google
# OIDC_GOOGLE_DISCOVERY_URL=https://accounts.google.com
# OIDC_GOOGLE_CLIENT_ID=your-client-id
#
# Example: Keycloak
# OIDC_KEYCLOAK_DISCOVERY_URL=https://keycloak.example.com/realms/myrealm
# OIDC_KEYCLOAK_CLIENT_ID=your-client-id
#
# Local development / e2e: there is NO verification bypass. Run the
# pilotable test IdP (ghcr.io/botresources/br-oidc-test-idp, see the
# br-e2e-harness repo) and declare it like any provider:
# OIDC_E2E_DISCOVERY_URL=http://localhost:9100
# OIDC_E2E_CLIENT_ID=e2e-client

# --- Required ---
NATS_URL=nats://nats:4222
JWT_SECRET=change-me-to-a-strong-random-secret

# --- Optional (defaults shown) ---
JWT_ISSUER=svc-auth
JWT_ACCESS_TOKEN_TTL=900          # 15 minutes
JWT_REFRESH_TOKEN_TTL=604800      # 7 days
PORT=8002
ENVIRONMENT=local                 # local | dev | test | prod
ALLOW_INSECURE=true               # Skip OIDC verification (local dev only, rejected in prod)
SECURE_COOKIES=false              # Use __Host- prefix + Secure flag on cookies
RUST_LOG=info                     # tracing filter (debug, info, warn, error)

# --- OIDC providers (auto-detected by prefix) ---
# Each provider needs OIDC_{NAME}_DISCOVERY_URL and OIDC_{NAME}_CLIENT_ID.
# OIDC_{NAME}_EMAIL_CLAIM is optional (default: "email").
#
# Example: Entra (Microsoft)
# OIDC_ENTRA_DISCOVERY_URL=https://login.microsoftonline.com/{tenant}/v2.0
# OIDC_ENTRA_CLIENT_ID=your-client-id
# OIDC_ENTRA_EMAIL_CLAIM=preferred_username
#
# Example: Google
# OIDC_GOOGLE_DISCOVERY_URL=https://accounts.google.com
# OIDC_GOOGLE_CLIENT_ID=your-client-id
#
# Example: Keycloak
# OIDC_KEYCLOAK_DISCOVERY_URL=https://keycloak.example.com/realms/myrealm
# OIDC_KEYCLOAK_CLIENT_ID=your-client-id
